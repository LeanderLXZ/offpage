# Extraction runtime artifacts (lock, progress, summaries, splits)
works/*/analysis/.extraction.lock
works/*/analysis/.scene_archive.lock
works/*/analysis/progress/
works/*/analysis/chapter_summaries/
works/*/analysis/scene_splits/

# Large novel corpus and derived source data
sources/raw/*
!sources/raw/.gitkeep
sources/works/*/raw/
sources/works/*/normalized/
sources/works/*/chapters/
sources/works/*/scenes/
sources/works/*/chunks/
sources/works/*/metadata/
sources/works/*/rag/

# Retrieval artifacts (large, generated at runtime)
works/*/retrieval/

# Evidence artifacts (large intermediate outputs)
analysis/evidence/*
!analysis/evidence/.gitkeep
works/*/analysis/evidence/*
!works/*/analysis/evidence/.gitkeep

# User data, relationship memory, and session artifacts
# Keep real user packages local; only the structural README stays tracked.
users/*
!users/README.md
!users/_template

# Common local data / database / index artifacts
*.db
*.sqlite
*.sqlite3
*.duckdb
*.parquet
*.faiss
*.ann
*.bin
*.npy
*.npz

# Python bytecode
__pycache__/
*.pyc

# Claude Code local config
.claude/

# IDE / editor history
.history/

# Local environment noise
.DS_Store
Thumbs.db
