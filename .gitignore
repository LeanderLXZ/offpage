# Large novel corpus and derived source data
sources/raw/*
!sources/raw/.gitkeep
sources/works/*
!sources/works/.gitkeep
sources/works/*/raw/
sources/works/*/normalized/
sources/works/*/chapters/
sources/works/*/scenes/
sources/works/*/chunks/
sources/works/*/metadata/
sources/works/*/rag/

# Incremental analysis outputs and evidence artifacts
analysis/incremental/*
!analysis/incremental/.gitkeep
analysis/evidence/*
!analysis/evidence/.gitkeep
works/*/analysis/evidence/*
!works/*/analysis/evidence/.gitkeep
works/*/indexes/*
!works/*/indexes/.gitkeep

# Local historical logs
docs/logs/*.md
!docs/logs/README.md

# User data, relationship memory, and session artifacts
# Keep real user packages local; only the structural README stays tracked.
users/*
!users/README.md

# Common local data / database / index artifacts
*.db
*.sqlite
*.sqlite3
*.duckdb
*.parquet
*.faiss
*.ann
*.bin
*.npy
*.npz

# Local environment noise
.DS_Store
Thumbs.db
