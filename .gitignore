# ===== Extraction runtime artifacts =====
# Locks, progress, summaries, splits — regenerated each run, never tracked.
works/*/analysis/.extraction.lock
works/*/analysis/.scene_archive.lock
works/*/analysis/progress/
works/*/analysis/chapter_summaries/
works/*/analysis/scene_splits/

# ===== Generated retrieval / evidence artifacts =====
# Large intermediate outputs, regenerated on demand.
works/*/retrieval/
works/*/analysis/evidence/*
!works/*/analysis/evidence/.gitkeep

# ===== Source corpus =====
# Raw novels and derived source data: large, copyrighted, never tracked.
sources/raw/*
!sources/raw/.gitkeep
sources/works/*/raw/
sources/works/*/normalized/
sources/works/*/chapters/
sources/works/*/scenes/
sources/works/*/chunks/
sources/works/*/metadata/

# Per-work source manifests carry the real work_id; keep them off main.
# `_template/` is exempt — it stays tracked for scaffolding.
sources/works/[!_]*/manifest.json

# ===== User data =====
# Real user packages stay local; only the structural template + README track.
users/*
!users/README.md
!users/_template

# ===== Local databases / indexes =====
*.db
*.sqlite
*.sqlite3
*.duckdb
*.parquet
*.faiss
*.ann
*.bin
*.npy
*.npz

# ===== Local config overrides =====
# Per-deployment, never committed.
automation/config.local.toml
.claude/settings.json
.claude/settings.local.json
.claude/*.lock

# ===== Tool / OS artifacts =====
__pycache__/
*.pyc
.history/
.DS_Store
Thumbs.db
