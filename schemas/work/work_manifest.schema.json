{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "offpage/work/work_manifest.schema.json",
  "title": "作品清单",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "title",
    "source_types",
    "ingestion_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身可以直接是中文，`sources/works/` 与 `works/` 下的根目录也应与之保持一致。"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string"
    },
    "source_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "web",
          "epub",
          "txt",
          "manual_excerpt",
          "summary"
        ]
      }
    },
    "ingestion_status": {
      "type": "string",
      "enum": [
        "planned",
        "raw_imported",
        "normalized",
        "chunked",
        "indexed",
        "active"
      ]
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_root": {
          "type": "string"
        },
        "normalized_root": {
          "type": "string"
        },
        "chapter_root": {
          "type": "string"
        },
        "scene_root": {
          "type": "string"
        },
        "chunk_root": {
          "type": "string"
        },
        "rag_root": {
          "type": "string"
        }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_stage_size": {
          "type": "integer",
          "minimum": 1,
          "description": "默认抽取阶段大小，单位为章节数。若未显式覆盖，推荐默认值为 10。"
        },
        "stage_is_cumulative": {
          "type": "boolean",
          "description": "若为 true，则阶段 N 的抽取范围默认为累计到 1..N。"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
