{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/character/boundaries.schema.json",
  "title": "角色人设边界",
  "description": "角色人设边界。hard_boundaries 是运行时始终加载的硬约束，不可阶段覆写。soft_boundaries 和 common_misconceptions 在运行时由 stage_snapshot 的 boundary_state 提供当前阶段的有效状态，此文件仅在提取阶段作为参照锚点。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "character_id",
    "hard_boundaries"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "string",
      "minLength": 1
    },
    "hard_boundaries": {
      "type": "array",
      "maxItems": 15,
      "description": "硬边界：角色在任何情况下都绝对不会做的事。例如：不会背叛某人、不会求饶、不会对弱者下手。最多 15 条。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule"],
        "properties": {
          "rule": {
            "type": "string",
            "maxLength": 50,
            "description": "边界规则描述。上限 50 字。"
          },
          "reason": {
            "type": "string",
            "maxLength": 50,
            "description": "为什么这是硬边界。例如：源于角色的核心价值观、源于角色的创伤经历。上限 50 字。"
          }
        }
      }
    },
    "soft_boundaries": {
      "type": "array",
      "maxItems": 15,
      "description": "软边界：角色强烈抗拒但在极端情况下可能被迫打破的行为。需要标注什么条件可能导致打破。最多 15 条。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule"],
        "properties": {
          "rule": {
            "type": "string",
            "maxLength": 50,
            "description": "边界规则描述。上限 50 字。"
          },
          "exception_condition": {
            "type": "string",
            "maxLength": 50,
            "description": "什么极端条件可能导致打破这条边界。例如：在意的人生命受到威胁时。上限 50 字。"
          }
        }
      }
    },
    "common_misconceptions": {
      "type": "array",
      "maxItems": 15,
      "description": "对这个角色的常见误解。标注人们容易搞错的地方。例如：虽然表面冷漠但并不是无情、虽然强势但不是不讲理。最多 15 条。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["misconception", "reality"],
        "properties": {
          "misconception": {
            "type": "string",
            "maxLength": 50,
            "description": "常见的错误认知。上限 50 字。"
          },
          "reality": {
            "type": "string",
            "maxLength": 100,
            "description": "实际情况是什么。上限 100 字。"
          }
        }
      }
    }
  }
}
