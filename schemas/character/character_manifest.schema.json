{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/character/character_manifest.schema.json",
  "title": "角色清单",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "character_id",
    "work_id",
    "canonical_name"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级基础角色标识。对于中文作品，优先直接使用原始中文角色名，而不是拼音 id。"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "canonical_name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "description": "所有别名的扁平列表（纯名称字符串），用于快速查找和匹配。完整的结构化别名信息存放在 identity.json 的 aliases 字段中。",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "role_labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canon_root": {
          "type": "string",
          "description": "角色包根路径。当 character_id 为中文时，这条路径里由它派生出来的文件夹段也应使用相同中文标识。"
        },
        "stage_catalog_path": {
          "type": "string",
          "description": "角色包内的阶段目录路径。repo 级结构段可以保持稳定，但由标识值派生出来的路径段应跟随基础角色标识。"
        },
        "stage_snapshot_root": {
          "type": "string",
          "description": "阶段快照根路径。该根路径下每个快照文件名形如 {stage_id}.json，stage_id 使用紧凑英文代号 S###。"
        },
        "evidence_root": {
          "type": "string"
        }
      }
    },
    "source_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "included_chapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
