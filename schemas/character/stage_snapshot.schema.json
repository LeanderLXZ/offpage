{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/character/stage_snapshot.schema.json",
  "title": "阶段快照",
  "description": "自包含的角色阶段快照。每个快照包含该阶段的完整角色状态，运行时直接加载无需与 baseline 合并。baseline 文件（voice_rules、behavior_rules、boundaries）仅在提取阶段作为参照锚点使用。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "character_id",
    "stage_id",
    "title",
    "snapshot_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级阶段标识。对于中文作品，这个值可以直接是中文。"
    },
    "title": {
      "type": "string"
    },
    "timeline_anchor": {
      "type": "string"
    },
    "snapshot_summary": {
      "type": "string"
    },
    "active_aliases": {
      "type": "object",
      "description": "当前阶段角色的活跃名称信息。标注角色在本阶段使用的名称、隐藏的身份、以及不同角色对其的称呼。",
      "additionalProperties": false,
      "properties": {
        "primary_name": {
          "type": "string",
          "description": "角色在本阶段最常用的名称。可能与 canonical_name 不同（如化名期间）。"
        },
        "active_names": {
          "type": "array",
          "description": "本阶段角色正在使用的所有名称（包括 primary_name）。可以是简单字符串，也可以是带语境的对象。",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "context": {
                    "type": "string",
                    "description": "使用该名称的语境。例如：'战斗时'、'日常交流'、'正式场合'。"
                  }
                }
              }
            ]
          }
        },
        "hidden_identities": {
          "type": "array",
          "description": "本阶段角色刻意隐藏的身份/名称。例如：角色化名活动时，其真实身份属于隐藏身份。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "hidden_from": {
                "type": "string",
                "description": "对谁隐藏。可以是角色 ID、'所有人'等。"
              },
              "reason": { "type": "string" }
            }
          }
        },
        "known_as": {
          "type": "object",
          "description": "不同角色对本角色的称呼映射。键为 character_id，值为该角色对本角色使用的称呼列表。",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "chapter_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },
    "stage_events": {
      "type": "array",
      "description": "仅本阶段发生的关键事件清单（不累积历史），每条为 50–80 字的一句话摘要。历史跨阶段视图由 world_event_digest / memory_timeline 提供。",
      "maxItems": 10,
      "items": { "type": "string", "minLength": 50, "maxLength": 80 }
    },
    "current_status": {
      "type": "array",
      "description": "当前阶段角色的状态信息，例如生死、关系、等级、位置等。保留最核心重要的条目。",
      "maxItems": 10,
      "items": { "type": "string" }
    },
    "current_personality": {
      "type": "array",
      "description": "当前阶段下已经稳定显现的人格与处事倾向。保留核心倾向。",
      "maxItems": 10,
      "items": { "type": "string" }
    },
    "current_mood": {
      "type": "array",
      "description": "当前阶段下更接近现在进行时的情绪背景。",
      "maxItems": 10,
      "items": { "type": "string" }
    },
    "knowledge_scope": {
      "type": "object",
      "additionalProperties": false,
      "description": "角色当前阶段的认知边界。条目数上限：knows ≤ 50、does_not_know ≤ 30、uncertain ≤ 30；每条字符串 ≤ 50 字。超限时按关联度裁剪：优先保留影响当前决策或关联 core_wounds/active_obsessions/活跃 relationships 的条目；常识、无触发点的早期细节、已由 memory_timeline 承载的条目可丢弃。",
      "properties": {
        "knows": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 50 }
        },
        "does_not_know": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 50 }
        },
        "uncertain": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 50 }
        }
      }
    },
    "emotional_baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dominant_traits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "active_goals": {
          "type": "array",
          "description": "当前阶段活跃的理性目标。",
          "items": { "type": "string" }
        },
        "active_obsessions": {
          "type": "array",
          "description": "当前阶段活跃的执念——非理性的、无法放下的心结。",
          "items": { "type": "string" }
        },
        "active_fears": {
          "type": "array",
          "items": { "type": "string" }
        },
        "active_wounds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "voice_state": {
      "type": "object",
      "description": "当前阶段的完整语言风格状态。自包含，无需与 baseline voice_rules 合并。",
      "additionalProperties": false,
      "properties": {
        "tone_summary": {
          "type": "string",
          "description": "当前阶段的整体语气基调。"
        },
        "speech_patterns": {
          "type": "array",
          "description": "当前阶段的语言习惯。",
          "items": { "type": "string" }
        },
        "vocabulary_preferences": {
          "type": "array",
          "description": "当前阶段的用词偏好。",
          "items": { "type": "string" }
        },
        "signature_phrases": {
          "type": "array",
          "description": "当前阶段的口头禅和标志性表达。",
          "items": { "type": "string" }
        },
        "taboo_patterns": {
          "type": "array",
          "description": "当前阶段绝不会说的话。",
          "items": { "type": "string" }
        },
        "dialogue_examples": {
          "type": "array",
          "description": "当前阶段的典型对话示例。",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "quote": { "type": "string" },
              "context": { "type": "string" },
              "evidence_ref": { "type": "string" }
            }
          }
        },
        "emotional_voice_map": {
          "type": "array",
          "description": "当前阶段下不同情绪的语气变化。保留最重要、最常见的情绪。",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["emotion"],
            "properties": {
              "emotion": {
                "type": "string",
                "description": "情绪标签。例如：暧昧、愤怒、委屈、嘴硬、关心、吃醋。"
              },
              "voice_shift": { "type": "string" },
              "typical_expressions": {
                "type": "array",
                "maxItems": 15,
                "items": { "type": "string" }
              },
              "dialogue_examples": {
                "type": "array",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "quote": { "type": "string" },
                    "context": { "type": "string" },
                    "evidence_ref": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "target_voice_map": {
          "type": "array",
          "description": "当前阶段下面对不同对象的语气变化。运行时按用户角色过滤加载。只对主要角色和重要配角详细记录（每 target 至少 3-5 条对话示例），泛化类型（陌生人、路人等）简要描述即可。",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_type"],
            "properties": {
              "target_type": {
                "type": "string",
                "description": "对象类型或具体角色。例如：角色A（真面目）、角色B、系统、村民、小孩。对重要角色使用具体名称而非泛化类型。"
              },
              "voice_shift": {
                "type": "string",
                "description": "面对该对象时语气的整体变化描述。"
              },
              "typical_expressions": {
                "type": "array",
                "description": "面对该对象时的典型表达列表。",
                "maxItems": 15,
                "items": { "type": "string" }
              },
              "dialogue_examples": {
                "type": "array",
                "description": "原文中面对该对象的对话示例。主要角色和重要配角要求至少 3-5 条，覆盖多种情绪和场景；泛化类型可简要。",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "quote": { "type": "string" },
                    "context": { "type": "string" },
                    "evidence_ref": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "behavior_state": {
      "type": "object",
      "description": "当前阶段的完整行为规则状态。自包含，无需与 baseline behavior_rules 合并。",
      "additionalProperties": false,
      "properties": {
        "core_goals": {
          "type": "array",
          "description": "当前阶段的理性目标——角色有意识追求的、可权衡调整的目标。",
          "items": { "type": "string" }
        },
        "obsessions": {
          "type": "array",
          "description": "当前阶段的执念——非理性的心结或驱动力，与核心创伤或强烈情感相关，不受理性权衡控制。",
          "items": { "type": "string" }
        },
        "decision_making_style": {
          "type": "string",
          "description": "当前阶段的决策风格。"
        },
        "emotional_triggers": {
          "type": "array",
          "description": "当前阶段的情绪触发器。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["trigger"],
            "properties": {
              "trigger": { "type": "string" },
              "reaction": { "type": "string" },
              "intensity": {
                "type": "string",
                "enum": ["mild", "moderate", "strong", "extreme"]
              }
            }
          }
        },
        "emotional_reaction_map": {
          "type": "array",
          "description": "当前阶段下不同情绪的行为反应模式。保留最重要、最常见的情绪。",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["emotion"],
            "properties": {
              "emotion": { "type": "string" },
              "internal_response": { "type": "string" },
              "external_behavior": { "type": "string" },
              "typical_actions": {
                "type": "array",
                "maxItems": 5,
                "items": { "type": "string" }
              },
              "recovery_pattern": { "type": "string" }
            }
          }
        },
        "target_behavior_map": {
          "type": "array",
          "description": "当前阶段下面对不同对象的具体行为模式。与 voice_state.target_voice_map 平行且对齐，侧重肢体反应、距离感、习惯性动作、回避模式等行为差异。运行时按用户角色过滤加载。只对主要角色和重要配角详细记录（每 target 至少 3-5 条行为示例），泛化类型简要描述即可。",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_type"],
            "properties": {
              "target_type": {
                "type": "string",
                "description": "对象类型或具体角色。例如：角色A（真面目）、角色B、系统、村民。"
              },
              "behavior_shift": {
                "type": "string",
                "description": "面对该对象时行为模式的整体变化描述。"
              },
              "typical_actions": {
                "type": "array",
                "description": "面对该对象时的典型行为列表。",
                "maxItems": 5,
                "items": { "type": "string" }
              },
              "action_examples": {
                "type": "array",
                "description": "原文中面对该对象的具体行为示例。主要角色和重要配角要求至少 3-5 条、场景多样；泛化类型可简要。",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "action": {
                      "type": "string",
                      "description": "角色的具体行为描述。"
                    },
                    "context": {
                      "type": "string",
                      "description": "行为发生的场景和原因。"
                    },
                    "evidence_ref": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "habitual_behaviors": {
          "type": "array",
          "description": "当前阶段的习惯性行为。",
          "items": { "type": "string" }
        },
        "stress_response": {
          "type": "object",
          "description": "当前阶段的压力应对方式。",
          "additionalProperties": false,
          "properties": {
            "coping_style": { "type": "string" },
            "breaking_point": { "type": "string" },
            "post_crisis_behavior": { "type": "string" }
          }
        }
      }
    },

    "boundary_state": {
      "type": "object",
      "description": "当前阶段的完整边界状态。hard_boundaries 从 baseline boundaries.json 继承不变，soft_boundaries 为当前阶段的有效状态。",
      "additionalProperties": false,
      "properties": {
        "soft_boundaries": {
          "type": "array",
          "description": "当前阶段有效的软边界。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule"],
            "properties": {
              "rule": { "type": "string" },
              "exception_condition": { "type": "string" },
              "stage_note": {
                "type": "string",
                "description": "如果此边界相比初始状态有变化，说明原因。"
              }
            }
          }
        },
        "common_misconceptions": {
          "type": "array",
          "description": "当前阶段容易被误判的点。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["misconception"],
            "properties": {
              "misconception": { "type": "string" },
              "reality": { "type": "string" }
            }
          }
        }
      }
    },

    "relationship_state_summary": {
      "type": "string"
    },
    "relationships": {
      "type": "array",
      "description": "当前阶段角色对每个重要角色的完整关系状态。不包含边缘的不重要角色。",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_label",
          "summary",
          "attitude"
        ],
        "properties": {
          "target_character_id": {
            "type": "string",
            "minLength": 1,
            "description": "被引用的基础角色标识。对于中文作品，这个值可以直接是中文。"
          },
          "target_label": {
            "type": "string",
            "description": "当前阶段的关系标签。例如：仇人、挚爱、师父、盟友。"
          },
          "summary": {
            "type": "string",
            "description": "当前阶段关系的简要描述。"
          },
          "attitude": {
            "type": "string",
            "description": "当前阶段对该角色的态度。例如：深爱且极度担忧、敌意但有所动摇、悲痛欲绝。"
          },
          "trust": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "intimacy": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "亲密度。0 = 陌生，100 = 至亲至爱。"
          },
          "guardedness": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "voice_shift": {
            "type": "string",
            "description": "面对该角色时的语气变化。例如：语气变得温柔，偶尔撒娇；或：冷淡疏离，以敬语保持距离。"
          },
          "behavior_shift": {
            "type": "string",
            "description": "面对该角色时的行为模式变化。例如：愿意主动示弱，会流泪；或：绝不露出破绽，保持高压。"
          },
          "driving_events": {
            "type": "array",
            "description": "驱动当前关系状态的关键事件。",
            "items": { "type": "string" }
          },
          "target_known_status": {
            "type": "string",
            "description": "角色认为该对象的当前状态。例如：alive、dead、missing、unknown。注意这是角色的认知，不一定是客观事实。"
          },
          "relationship_history_summary": {
            "type": "string",
            "maxLength": 300,
            "description": "从阶段 1 到当前阶段，这对关系的演变轨迹概述。应包含关键行为标记（称呼变化、态度转折点、知识揭露时点等）。上限 300 字（硬 schema 门控，L2 structural 同步校验；缺失/空串由 L2 以 warning 暴露）。"
          }
        }
      }
    },

    "misunderstandings": {
      "type": "array",
      "description": "角色在当前阶段持有的误解。角色主观认为是对的，但客观上是错误的认知。已 resolved 的误解（resolved_at_stage 非空且 ≤ 当前阶段）应移除。",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "误解的内容，用角色的主观视角描述。例如：认为某人已死、认为某人背叛了自己。"
          },
          "truth": {
            "type": "string",
            "description": "客观事实是什么。"
          },
          "cause": {
            "type": "string",
            "description": "产生误解的原因。例如：被人欺骗、信息不全、亲眼所见但被误导。"
          },
          "resolved_at_stage": {
            "type": "string",
            "description": "如果已知误解在哪个阶段被解开，填写对应 stage_id。空值表示截至当前阶段仍未解开。"
          }
        }
      }
    },
    "concealments": {
      "type": "array",
      "description": "角色在当前阶段主动隐瞒的事情。角色知道真相但选择不说。已 revealed 的隐瞒（revealed_at_stage 非空且 ≤ 当前阶段）应移除。",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "隐瞒的内容。例如：隐瞒自己的真实身份、隐瞒对某人的感情。"
          },
          "target": {
            "type": "string",
            "description": "对谁隐瞒。可以是特定角色名或'所有人'。"
          },
          "reason": {
            "type": "string",
            "description": "隐瞒的原因。例如：保护对方、自我保护、羞耻、还没准备好。"
          },
          "revealed_at_stage": {
            "type": "string",
            "description": "如果已知在哪个阶段被揭露或主动坦白，填写对应 stage_id。空值表示截至当前阶段仍在隐瞒。"
          }
        }
      }
    },

    "stage_delta": {
      "type": "object",
      "description": "从上一个阶段到当前阶段的关键变化摘要。第一个阶段此字段可省略。",
      "additionalProperties": false,
      "properties": {
        "trigger_events": {
          "type": "array",
          "description": "驱动本阶段变化的关键事件。",
          "items": { "type": "string" }
        },
        "personality_changes": {
          "type": "array",
          "description": "性格上的变化（相比上一阶段）。每条应标注影响来源。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["change"],
            "properties": {
              "change": {
                "type": "string",
                "description": "性格变化描述。例如：开始相信人间有真情，不再认为所有人都会背叛。"
              },
              "influenced_by": {
                "type": "string",
                "description": "导致此变化的角色或事件。例如：受某关键他人的自我牺牲行为影响。"
              }
            }
          }
        },
        "relationship_changes": {
          "type": "array",
          "description": "关系上的变化（相比上一阶段）。每条应标注驱动事件。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["change"],
            "properties": {
              "change": {
                "type": "string",
                "description": "关系变化描述。例如：对某重要他人从戒备转为信任。"
              },
              "driving_event": {
                "type": "string",
                "description": "驱动此关系变化的事件。例如：关键他人做出重大自我牺牲的行为。"
              }
            }
          }
        },
        "status_changes": {
          "type": "array",
          "description": "状态上的变化（等级、地位、生死等）。",
          "items": { "type": "string" }
        },
        "mood_shift": {
          "type": "string",
          "description": "情绪基调的变化。例如：从迷茫转为坚定、从信任转为戒备。"
        },
        "voice_shift": {
          "type": "string",
          "description": "口吻的变化。例如：变得更冷漠、开始用敬语、不再掩饰情绪。"
        }
      }
    },

    "character_arc": {
      "type": "object",
      "description": "角色从阶段 1 到当前阶段的整体弧线概览。第一个阶段可省略或仅写起点状态。与 stage_delta（记录单阶段变化）互补：character_arc 提供全局俯瞰视角。",
      "additionalProperties": false,
      "properties": {
        "arc_summary": {
          "type": "string",
          "description": "一句话概括角色从起点到当前的核心变化轨迹。例如：'从初始封闭/戒备状态，经关键他人持续的善意接触，逐步转向选择性信任与依赖'。"
        },
        "arc_stages": {
          "type": "array",
          "description": "弧线的关键节点列表（按时间顺序），每个节点描述一个弧线阶段。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage_id", "description"],
            "properties": {
              "stage_id": {
                "type": "string",
                "description": "对应的阶段 ID。"
              },
              "description": {
                "type": "string",
                "description": "该阶段在弧线中的角色状态和变化。例如：'冰冷疏离→首次接受善意→主动疗伤'。"
              }
            }
          }
        },
        "current_position": {
          "type": "string",
          "description": "角色当前在弧线中的位置和趋势。例如：'冰层下的情感开始自发泄漏，但离主动承认还很远'。"
        }
      }
    },

    "memory_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
