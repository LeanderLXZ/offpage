{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "offpage/character/stage_snapshot.schema.json",
  "title": "阶段快照",
  "description": "自包含的角色阶段快照。每个快照包含该阶段的完整角色状态，运行时直接加载无需与 baseline 合并。baseline 文件（voice_rules、behavior_rules、boundaries）仅在提取阶段作为参照锚点使用。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "character_id",
    "stage_id",
    "stage_title",
    "timeline_anchor",
    "snapshot_summary",
    "active_aliases",
    "current_personality",
    "current_mood",
    "knowledge_scope",
    "voice_state",
    "behavior_state",
    "boundary_state",
    "relationships",
    "stage_events",
    "character_arc"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "stage_id": {
      "type": "string",
      "pattern": "^S[0-9]{3}$",
      "description": "作品级阶段标识，紧凑英文代号格式 S###（三位数字零填充，如 S001），与 M-S###-## / E-S###-## / SC-S###-## / SN-S###-## 家族对齐。阶段名称见 stage_title。"
    },
    "stage_title": {
      "type": "string",
      "description": "阶段的人类可读短标题。从 stage_plan.json 的同 stage_id 条目拉取；bound 由 stage_plan.schema.json 单源定义，本 schema 不重复约束。"
    },
    "timeline_anchor": {
      "type": "string",
      "maxLength": 50,
      "description": "阶段时间锚点的短描述。上限 50 字。"
    },
    "snapshot_summary": {
      "type": "string",
      "minLength": 100,
      "maxLength": 200,
      "description": "当前阶段快照的一段式摘要。100–200 字。"
    },
    "active_aliases": {
      "type": "object",
      "description": "当前阶段角色的活跃名称信息。标注角色在本阶段使用的名称、隐藏的身份、以及不同角色对其的称呼。",
      "additionalProperties": false,
      "properties": {
        "primary_name": {
          "type": "string",
          "description": "角色在本阶段最常用的名称。可能与 canonical_name 不同（如化名期间）。"
        },
        "active_names": {
          "type": "array",
          "maxItems": 5,
          "description": "本阶段角色正在使用的所有名称（包括 primary_name）。可以是简单字符串，也可以是带语境的对象。最多 5 条。",
          "items": {
            "oneOf": [
              { "type": "string", "maxLength": 10 },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "maxLength": 10 },
                  "context": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "使用该名称的语境。例如：'战斗时'、'日常交流'、'正式场合'。上限 50 字。"
                  }
                }
              }
            ]
          }
        },
        "hidden_identities": {
          "type": "array",
          "maxItems": 5,
          "description": "本阶段角色刻意隐藏的身份/名称。例如：角色化名活动时，其真实身份属于隐藏身份。最多 5 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "maxLength": 10 },
              "hidden_from": {
                "type": "string",
                "description": "对谁隐藏。可以是角色 ID、'所有人'等。"
              },
              "reason": {
                "type": "string",
                "maxLength": 50,
                "description": "隐藏原因。上限 50 字。"
              }
            }
          }
        },
        "known_as": {
          "type": "object",
          "maxProperties": 10,
          "description": "不同角色对本角色的称呼映射。键为 character_id，值为该角色对本角色使用的称呼列表。最多 10 个映射。",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "chapter_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" }
      }
    },
    "stage_events": {
      "type": "array",
      "description": "**该角色相关的本阶段关键事件**清单（不累积历史），每条为 50–80 字的一句话摘要。归属判定：① 该角色亲历 / 亲为 / 在场 / 直接影响其处境或认知的事件才写入；② 其他角色之间的私事、与该角色无关的对话或经济活动一律不写入；③ 世界级公共事件（势力变迁、boss 复活、天灾、奇观等）由 world `stage_events` 承载，**不要直接复制世界层文本**——仅当该角色亲历该世界事件时，才以**角色视角**重写一条进入此清单（角色看到 / 经历 / 应对的是什么）。历史跨阶段视图由 memory_timeline / memory_digest / world_event_digest 提供。",
      "maxItems": 15,
      "items": { "type": "string", "minLength": 50, "maxLength": 80 }
    },
    "current_status": {
      "type": "array",
      "description": "当前阶段角色的状态信息，例如生死、关系、等级、位置等。保留最核心重要的条目。最多 10 条，每条 ≤ 50 字。",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 50 }
    },
    "current_personality": {
      "type": "array",
      "description": "当前阶段下已经稳定显现的人格与处事倾向。保留核心倾向。最多 10 条，每条 ≤ 50 字。",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 50 }
    },
    "current_mood": {
      "type": "array",
      "description": "当前阶段下更接近现在进行时的情绪背景。最多 10 条，每条 ≤ 50 字。",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 50 }
    },
    "knowledge_scope": {
      "type": "object",
      "additionalProperties": false,
      "description": "角色当前阶段的认知边界。条目数上限：knows ≤ 50、does_not_know ≤ 30、uncertain ≤ 30；每条字符串 ≤ 50 字。超限时按关联度裁剪：优先保留影响当前决策或关联 core_wounds/active_obsessions/活跃 relationships 的条目；常识、无触发点的早期细节、已由 memory_timeline 承载的条目可丢弃。",
      "properties": {
        "knows": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 50 }
        },
        "does_not_know": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 50 }
        },
        "uncertain": {
          "type": "array",
          "maxItems": 30,
          "items": { "type": "string", "maxLength": 50 }
        }
      }
    },
    "emotional_baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dominant_traits": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段的主导性格特质。最多 10 条，每条 ≤ 15 字。",
          "items": { "type": "string", "maxLength": 15 }
        },
        "active_goals": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段活跃的理性目标。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "active_obsessions": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段活跃的执念——非理性的、无法放下的心结。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "active_fears": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段活跃的恐惧。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "active_wounds": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段活跃的创伤。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        }
      }
    },

    "voice_state": {
      "type": "object",
      "description": "当前阶段的完整语言风格状态。自包含，无需与 baseline voice_rules 合并。",
      "additionalProperties": false,
      "properties": {
        "tone_summary": {
          "type": "string",
          "maxLength": 100,
          "description": "当前阶段的整体语气基调。上限 100 字。"
        },
        "speech_patterns": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段的语言习惯。最多 15 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "vocabulary_preferences": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段的用词偏好。最多 15 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "signature_phrases": {
          "type": "array",
          "maxItems": 30,
          "description": "当前阶段的口头禅和标志性表达。最多 30 条，每条 ≤ 10 字。",
          "items": { "type": "string", "maxLength": 10 }
        },
        "taboo_patterns": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段绝不会说的话。最多 15 条，每条 ≤ 30 字。",
          "items": { "type": "string", "maxLength": 30 }
        },
        "dialogue_examples": {
          "type": "array",
          "description": "当前阶段的典型对话示例。最多 10 条。",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["quote", "context"],
            "properties": {
              "quote": { "type": "string", "maxLength": 30 },
              "context": { "type": "string", "maxLength": 50 }
            }
          }
        },
        "emotional_voice_map": {
          "type": "array",
          "description": "当前阶段下不同情绪的语气变化。保留最重要、最常见的情绪。最多 15 条。",
          "maxItems": 15,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["emotion"],
            "properties": {
              "emotion": {
                "type": "string",
                "maxLength": 10,
                "description": "情绪标签。例如：暧昧、愤怒、委屈、嘴硬、关心、吃醋。上限 10 字。"
              },
              "voice_shift": {
                "type": "string",
                "maxLength": 50,
                "description": "该情绪下语气的整体变化描述。上限 50 字。"
              },
              "typical_expressions": {
                "type": "array",
                "maxItems": 10,
                "description": "这种情绪下的典型表达方式或句式。最多 10 条，每条 ≤ 15 字。",
                "items": { "type": "string", "maxLength": 15 }
              },
              "dialogue_examples": {
                "type": "array",
                "maxItems": 10,
                "description": "这种情绪下的代表性对话示例。最多 10 条。",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["quote", "context"],
                  "properties": {
                    "quote": { "type": "string", "maxLength": 30 },
                    "context": { "type": "string", "maxLength": 50 }
                  }
                }
              }
            }
          }
        },
        "target_voice_map": {
          "type": "array",
          "description": "当前阶段下面对不同对象的语气变化。运行时按用户角色过滤加载。只对主要角色和重要配角详细记录（每 target 至少 3-5 条对话示例），泛化类型（陌生人、路人等）简要描述即可。最多 10 条。",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_type"],
            "properties": {
              "target_type": {
                "type": "string",
                "maxLength": 15,
                "description": "对象类型或具体角色。例如：角色A（真面目）、角色B、系统、村民、小孩。对重要角色使用具体名称而非泛化类型。上限 15 字。"
              },
              "voice_shift": {
                "type": "string",
                "maxLength": 50,
                "description": "面对该对象时语气的整体变化描述。上限 50 字。"
              },
              "typical_expressions": {
                "type": "array",
                "maxItems": 10,
                "description": "面对该对象时的典型表达列表。最多 10 条，每条 ≤ 15 字。",
                "items": { "type": "string", "maxLength": 15 }
              },
              "dialogue_examples": {
                "type": "array",
                "description": "原文中面对该对象的对话示例。最多 10 条。",
                "maxItems": 10,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["quote", "context"],
                  "properties": {
                    "quote": { "type": "string", "maxLength": 30 },
                    "context": { "type": "string", "maxLength": 50 }
                  }
                }
              }
            }
          }
        }
      }
    },

    "behavior_state": {
      "type": "object",
      "description": "当前阶段的完整行为规则状态。自包含，无需与 baseline behavior_rules 合并。",
      "additionalProperties": false,
      "properties": {
        "core_goals": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段的理性目标——角色有意识追求的、可权衡调整的目标。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "obsessions": {
          "type": "array",
          "maxItems": 10,
          "description": "当前阶段的执念——非理性的心结或驱动力，与核心创伤或强烈情感相关，不受理性权衡控制。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "decision_making_style": {
          "type": "string",
          "minLength": 50,
          "maxLength": 200,
          "description": "当前阶段的决策风格。50–200 字。"
        },
        "emotional_triggers": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段的情绪触发器。最多 15 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["trigger"],
            "properties": {
              "trigger": { "type": "string", "maxLength": 50 },
              "reaction": { "type": "string", "maxLength": 100 },
              "intensity": {
                "type": "string",
                "enum": ["mild", "moderate", "strong", "extreme"]
              }
            }
          }
        },
        "emotional_reaction_map": {
          "type": "array",
          "description": "当前阶段下不同情绪的行为反应模式。保留最重要、最常见的情绪。最多 15 条。",
          "maxItems": 15,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["emotion"],
            "properties": {
              "emotion": {
                "type": "string",
                "maxLength": 10,
                "description": "情绪标签。上限 10 字。"
              },
              "internal_response": {
                "type": "string",
                "maxLength": 50,
                "description": "内心感受。上限 50 字。"
              },
              "external_behavior": {
                "type": "string",
                "maxLength": 50,
                "description": "外在表现。上限 50 字。"
              },
              "typical_actions": {
                "type": "array",
                "maxItems": 5,
                "description": "这种情绪下的典型行为动作。最多 5 条，每条 ≤ 50 字。",
                "items": { "type": "string", "maxLength": 50 }
              },
              "recovery_pattern": {
                "type": "string",
                "maxLength": 50,
                "description": "恢复方式。上限 50 字。"
              }
            }
          }
        },
        "target_behavior_map": {
          "type": "array",
          "description": "当前阶段下面对不同对象的具体行为模式。与 voice_state.target_voice_map 平行且对齐，侧重肢体反应、距离感、习惯性动作、回避模式等行为差异。运行时按用户角色过滤加载。只对主要角色和重要配角详细记录（每 target 至少 3-5 条行为示例），泛化类型简要描述即可。最多 10 条。",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_type"],
            "properties": {
              "target_type": {
                "type": "string",
                "maxLength": 15,
                "description": "对象类型或具体角色。例如：角色A（真面目）、角色B、系统、村民。上限 15 字。"
              },
              "behavior_shift": {
                "type": "string",
                "maxLength": 100,
                "description": "面对该对象时行为模式的整体变化描述。上限 100 字。"
              },
              "typical_actions": {
                "type": "array",
                "maxItems": 5,
                "description": "面对该对象时的典型行为列表。最多 5 条，每条 ≤ 50 字。",
                "items": { "type": "string", "maxLength": 50 }
              },
              "action_examples": {
                "type": "array",
                "description": "原文中面对该对象的具体行为示例。最多 5 条。",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["action", "context"],
                  "properties": {
                    "action": {
                      "type": "string",
                      "maxLength": 50,
                      "description": "角色的具体行为描述。上限 50 字。"
                    },
                    "context": {
                      "type": "string",
                      "maxLength": 100,
                      "description": "行为发生的场景和原因。上限 100 字。"
                    }
                  }
                }
              }
            }
          }
        },
        "habitual_behaviors": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段的习惯性行为。最多 15 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "stress_response": {
          "type": "object",
          "description": "当前阶段的压力应对方式。",
          "additionalProperties": false,
          "properties": {
            "coping_style": { "type": "string", "maxLength": 50 },
            "breaking_point": { "type": "string", "maxLength": 50 },
            "post_crisis_behavior": { "type": "string", "maxLength": 50 }
          }
        }
      }
    },

    "boundary_state": {
      "type": "object",
      "description": "当前阶段的完整边界状态。hard_boundaries 对应 baseline boundaries.json 的硬约束（阶段内通常不变）；soft_boundaries 为当前阶段的有效状态。",
      "additionalProperties": false,
      "properties": {
        "hard_boundaries": {
          "type": "array",
          "maxItems": 15,
          "description": "硬边界：角色在任何情况下都绝对不会做的事。例如：不会背叛某人、不会求饶、不会对弱者下手。最多 15 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule"],
            "properties": {
              "rule": {
                "type": "string",
                "maxLength": 50,
                "description": "边界规则描述。上限 50 字。"
              },
              "reason": {
                "type": "string",
                "maxLength": 50,
                "description": "为什么这是硬边界。例如：源于角色的核心价值观、源于角色的创伤经历。上限 50 字。"
              }
            }
          }
        },
        "soft_boundaries": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段有效的软边界。最多 15 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule"],
            "properties": {
              "rule": { "type": "string", "maxLength": 50 },
              "exception_condition": { "type": "string", "maxLength": 50 },
              "stage_note": {
                "type": "string",
                "maxLength": 50,
                "description": "如果此边界相比初始状态有变化，说明原因。上限 50 字。"
              }
            }
          }
        },
        "common_misconceptions": {
          "type": "array",
          "maxItems": 15,
          "description": "当前阶段容易被误判的点。最多 15 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["misconception"],
            "properties": {
              "misconception": { "type": "string", "maxLength": 50 },
              "reality": { "type": "string", "maxLength": 100 }
            }
          }
        }
      }
    },

    "relationship_state_summary": {
      "type": "string",
      "maxLength": 100,
      "description": "当前阶段关系状态的总体摘要。上限 100 字。"
    },
    "relationships": {
      "type": "array",
      "description": "当前阶段角色对每个重要角色的完整关系状态。不包含边缘的不重要角色。最多 10 条。",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_label",
          "summary",
          "attitude"
        ],
        "properties": {
          "target_character_id": {
            "type": "string",
            "minLength": 1,
            "description": "被引用的基础角色标识。对于中文作品，这个值可以直接是中文。"
          },
          "target_label": {
            "type": "string",
            "maxLength": 30,
            "description": "当前阶段的关系标签。例如：仇人、挚爱、师父、盟友。上限 30 字。"
          },
          "summary": {
            "type": "string",
            "maxLength": 50,
            "description": "当前阶段关系的简要描述。上限 50 字。"
          },
          "attitude": {
            "type": "string",
            "maxLength": 50,
            "description": "当前阶段对该角色的态度。上限 50 字。"
          },
          "trust": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "intimacy": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "亲密度。0 = 陌生，100 = 至亲至爱。"
          },
          "guardedness": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "voice_shift": {
            "type": "string",
            "maxLength": 50,
            "description": "面对该角色时的语气变化。上限 50 字。"
          },
          "behavior_shift": {
            "type": "string",
            "maxLength": 50,
            "description": "面对该角色时的行为模式变化。上限 50 字。"
          },
          "driving_events": {
            "type": "array",
            "maxItems": 10,
            "description": "驱动当前关系状态的关键事件。最多 10 条，每条 ≤ 50 字。",
            "items": { "type": "string", "maxLength": 50 }
          },
          "target_known_status": {
            "type": "string",
            "maxLength": 50,
            "description": "角色认为该对象的当前状态。例如：alive、dead、missing、unknown。注意这是角色的认知，不一定是客观事实。上限 50 字。"
          },
          "relationship_history_summary": {
            "type": "string",
            "maxLength": 100,
            "description": "从阶段 1 到当前阶段，这对关系的演变轨迹概述。应包含关键行为标记（称呼变化、态度转折点、知识揭露时点等）。上限 100 字。"
          }
        }
      }
    },

    "misunderstandings": {
      "type": "array",
      "description": "角色在当前阶段持有的误解。角色主观认为是对的，但客观上是错误的认知。已 resolved 的误解（resolved_at_stage 非空且 ≤ 当前阶段）应移除。最多 15 条。",
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "maxLength": 50,
            "description": "误解的内容，用角色的主观视角描述。上限 50 字。"
          },
          "truth": {
            "type": "string",
            "maxLength": 50,
            "description": "客观事实是什么。上限 50 字。"
          },
          "cause": {
            "type": "string",
            "maxLength": 50,
            "description": "产生误解的原因。上限 50 字。"
          },
          "resolved_at_stage": {
            "type": "string",
            "pattern": "^(S[0-9]{3})?$",
            "description": "如果已知误解在哪个阶段被解开，填写对应 stage_id（紧凑英文代号 S###）。空值表示截至当前阶段仍未解开。"
          }
        }
      }
    },
    "concealments": {
      "type": "array",
      "description": "角色在当前阶段主动隐瞒的事情。角色知道真相但选择不说。已 revealed 的隐瞒（revealed_at_stage 非空且 ≤ 当前阶段）应移除。最多 15 条。",
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "maxLength": 50,
            "description": "隐瞒的内容。上限 50 字。"
          },
          "target": {
            "type": "string",
            "description": "对谁隐瞒。可以是特定角色名或'所有人'。"
          },
          "reason": {
            "type": "string",
            "maxLength": 50,
            "description": "隐瞒的原因。上限 50 字。"
          },
          "revealed_at_stage": {
            "type": "string",
            "pattern": "^(S[0-9]{3})?$",
            "description": "如果已知在哪个阶段被揭露或主动坦白，填写对应 stage_id（紧凑英文代号 S###）。空值表示截至当前阶段仍在隐瞒。"
          }
        }
      }
    },

    "stage_delta": {
      "type": "object",
      "description": "从上一个阶段到当前阶段的关键变化摘要。第一个阶段此字段可省略。",
      "additionalProperties": false,
      "properties": {
        "trigger_events": {
          "type": "array",
          "maxItems": 10,
          "description": "驱动本阶段变化的关键事件。最多 10 条，每条 ≤ 50 字。",
          "items": { "type": "string", "maxLength": 50 }
        },
        "personality_changes": {
          "type": "array",
          "maxItems": 10,
          "description": "性格上的变化（相比上一阶段）。最多 10 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["change"],
            "properties": {
              "change": {
                "type": "string",
                "maxLength": 50,
                "description": "性格变化描述。上限 50 字。"
              },
              "influenced_by": {
                "type": "string",
                "maxLength": 30,
                "description": "导致此变化的角色或事件。上限 30 字。"
              }
            }
          }
        },
        "relationship_changes": {
          "type": "array",
          "maxItems": 10,
          "description": "关系上的变化（相比上一阶段）。最多 10 条。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["change"],
            "properties": {
              "change": {
                "type": "string",
                "maxLength": 50,
                "description": "关系变化描述。上限 50 字。"
              },
              "driving_event": {
                "type": "string",
                "maxLength": 50,
                "description": "驱动此关系变化的事件。上限 50 字。"
              }
            }
          }
        },
        "status_changes": {
          "type": "array",
          "description": "状态上的变化（等级、地位、生死等）。",
          "items": { "type": "string" }
        },
        "mood_shift": {
          "type": "string",
          "maxLength": 100,
          "description": "情绪基调的变化。上限 100 字。"
        },
        "voice_shift": {
          "type": "string",
          "maxLength": 100,
          "description": "口吻的变化。上限 100 字。"
        }
      }
    },

    "character_arc": {
      "type": "string",
      "maxLength": 200,
      "description": "角色从阶段 1 到当前阶段的整体弧线概述。一句到一段话概括核心变化轨迹。上限 200 字。"
    }
  }
}
