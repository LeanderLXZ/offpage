{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "offpage/runtime/context_manifest.schema.json",
  "title": "上下文清单",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "context_id",
    "user_id",
    "work_id",
    "character_id",
    "stage_id",
    "lifecycle"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "context_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "user_id": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "当前上下文所属的作品命名空间标识。该值必须与当前 `users/{user_id}/` 锁定绑定一致。对于中文作品，这个值可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "当前上下文加载的基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "stage_id": {
      "type": "string",
      "pattern": "^S[0-9]{3}$",
      "description": "当前上下文选定的作品级活动阶段标识，紧凑英文代号 S###。world 与目标角色默认都应围绕该阶段装载。"
    },
    "counterpart_mode": {
      "type": "string",
      "enum": [
        "user_self",
        "user_persona",
        "canon_character",
        "custom_role"
      ],
      "description": "当前上下文中用户侧身份模式。"
    },
    "counterpart_persona_id": {
      "type": "string"
    },
    "counterpart_character_id": {
      "type": "string",
      "minLength": 1,
      "description": "当用户侧身份模式为 canon_character 时，该值表示用户侧角色绑定的基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "counterpart_stage_mode": {
      "type": "string",
      "enum": [
        "inherit_target_stage",
        "explicit_override"
      ],
      "description": "当用户侧身份模式为 canon_character 时，该值表示用户侧角色是继承目标阶段，还是显式覆盖为另一个阶段。"
    },
    "counterpart_stage_id": {
      "type": "string",
      "pattern": "^S[0-9]{3}$",
      "description": "当用户侧身份模式为 canon_character 且存在显式跨阶段 branch override 时，该值表示用户侧角色选定的阶段标识，紧凑英文代号 S###。默认运行时不应要求单独设置。"
    },
    "counterpart_label": {
      "type": "string"
    },
    "counterpart_summary": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "premise_summary": {
      "type": "string"
    },
    "lifecycle": {
      "type": "string",
      "enum": [
        "ephemeral",
        "persistent",
        "merged",
        "archived"
      ]
    },
    "origin_type": {
      "type": "string",
      "enum": [
        "new",
        "branch",
        "imported",
        "merged"
      ]
    },
    "origin_context_id": {
      "type": "string"
    },
    "active_session_id": {
      "type": "string"
    },
    "session_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "merge_policy": {
      "type": "string",
      "enum": [
        "manual_only",
        "allow_memory_pins",
        "allow_full_merge"
      ]
    },
    "writeback_policy": {
      "type": "string",
      "enum": [
        "continuous",
        "review_only",
        "manual_only"
      ]
    },
    "load_snapshot_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "world_stage_snapshot_path": {
          "type": "string"
        },
        "target_stage_snapshot_path": {
          "type": "string"
        },
        "counterpart_stage_snapshot_path": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "ended_by": {
      "type": "string",
      "enum": [
        "user",
        "system",
        "timeout",
        "other"
      ]
    },
    "end_reason": {
      "type": "string"
    },
    "merge_decision": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "declined",
        "not_offered"
      ]
    },
    "last_merged_at": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "counterpart_mode": {
            "const": "user_persona"
          }
        },
        "required": [
          "counterpart_mode"
        ]
      },
      "then": {
        "required": [
          "counterpart_persona_id"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_persona_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "user_persona"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        },
        "required": [
          "counterpart_mode"
        ]
      },
      "then": {
        "required": [
          "counterpart_character_id",
          "counterpart_stage_mode"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_character_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "counterpart_stage_mode"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "counterpart_stage_mode": {
            "const": "explicit_override"
          }
        },
        "required": [
          "counterpart_stage_mode"
        ]
      },
      "then": {
        "required": [
          "counterpart_stage_id"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_stage_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_stage_mode"
        ],
        "properties": {
          "counterpart_stage_mode": {
            "const": "explicit_override"
          }
        }
      }
    }
  ]
}
