{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "offpage/user/long_term_profile.schema.json",
  "title": "用户长期画像",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "user_id",
    "work_id",
    "character_id",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "current_self_summary": {
      "type": "string"
    },
    "current_persona_summary": {
      "type": "string"
    },
    "merged_context_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "event_history": {
      "type": "array",
      "description": "长期事件历史，推荐采用只增不删的追加写入策略。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_event_id",
          "summary"
        ],
        "properties": {
          "user_event_id": {
            "type": "string",
            "description": "用户命名空间内的事件 ID，由合并流程生成；与 works/* 正典事件（E-S###-##）不是同一命名空间，不跨层引用。"
          },
          "summary": {
            "type": "string"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "memory_history": {
      "type": "array",
      "description": "长期记忆点历史，推荐采用只增不删的追加写入策略。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_memory_id",
          "summary"
        ],
        "properties": {
          "user_memory_id": {
            "type": "string",
            "description": "用户命名空间内的记忆 ID，由合并流程生成；与 works/* 正典 memory_timeline（M-S###-##）不是同一命名空间，不跨层引用。"
          },
          "summary": {
            "type": "string"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "persona_shift_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_shift_id",
          "summary"
        ],
        "properties": {
          "user_shift_id": {
            "type": "string",
            "description": "用户命名空间内的画像漂移 ID，由合并流程生成。"
          },
          "summary": {
            "type": "string"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "character_drift_history": {
      "type": "array",
      "description": "模拟角色因与用户长期互动而产生的累积变化记录。从 context 合并时提炼写入，推荐追加不覆盖。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["user_drift_id", "summary"],
        "properties": {
          "user_drift_id": {
            "type": "string",
            "description": "用户命名空间内的角色漂移 ID，由合并流程生成。"
          },
          "category": {
            "type": "string",
            "enum": ["emotional", "personality", "voice", "behavior"],
            "description": "变化类别：情绪倾向、性格微调、口癖语气、行为模式。"
          },
          "summary": {
            "type": "string",
            "description": "变化描述，如：对用户的态度从冷淡转为主动关心。"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
