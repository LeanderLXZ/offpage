{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "offpage/user/relationship_core.schema.json",
  "title": "关系核心",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "user_id",
    "work_id",
    "character_id",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "该关系核心所属的作品命名空间标识。该值必须与当前 `users/{user_id}/` 锁定绑定一致。对于中文作品，这个值可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "该关系核心所引用的基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "current_relation_summary": {
      "type": "string"
    },
    "relationship_label": {
      "type": "string"
    },
    "trust_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "intimacy_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "dependence_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "merged_context_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "event_refs": {
      "type": "array",
      "description": "被提升为长期关系历史的事件引用。推荐采用只增不删的追加写入策略。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_event_id",
          "summary"
        ],
        "properties": {
          "user_event_id": {
            "type": "string",
            "description": "用户命名空间内的事件 ID，由合并流程生成；与 works/* 正典事件（E-S###-##）不是同一命名空间，不跨层引用。"
          },
          "summary": {
            "type": "string"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "profile_shift_refs": {
      "type": "array",
      "description": "指向长期画像变化记录的引用。推荐追加而不是覆盖。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "user_shift_id",
          "summary"
        ],
        "properties": {
          "user_shift_id": {
            "type": "string",
            "description": "用户命名空间内的画像漂移 ID，与 long_term_profile.persona_shift_history[].user_shift_id 保持一致。"
          },
          "summary": {
            "type": "string"
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "mutual_agreements": {
      "type": "array",
      "description": "从 context 合并提炼出的长期有效的双方约定或承诺。推荐追加写入。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["user_agreement_id", "summary"],
        "properties": {
          "user_agreement_id": {
            "type": "string",
            "description": "用户命名空间内的约定 ID，由合并流程生成。"
          },
          "summary": {
            "type": "string",
            "description": "约定内容，如：答应不再隐瞒身份、约定每天见面。"
          },
          "status": {
            "type": "string",
            "enum": ["active", "broken", "fulfilled", "withdrawn"]
          },
          "source_context_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "personalized_voice_shift": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nicknames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "softened_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triggered_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "personalized_behavior_shift": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "comfort_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "defense_triggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attachment_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
