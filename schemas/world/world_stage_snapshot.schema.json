{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world/world_stage_snapshot.schema.json",
  "title": "世界阶段快照",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "stage_id",
    "stage_title",
    "timeline_anchor",
    "location_anchor",
    "snapshot_summary",
    "foundation_corrections",
    "stage_events",
    "current_world_state",
    "relationship_shifts",
    "character_status_changes",
    "location_changes",
    "map_changes",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_id": {
      "type": "string",
      "pattern": "^S[0-9]{3}$",
      "description": "作品级阶段标识，紧凑英文代号 S###。"
    },
    "stage_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 15,
      "description": "阶段的人类可读短标题（≤15 字）。"
    },
    "timeline_anchor": {
      "type": "string",
      "maxLength": 15,
      "description": "本阶段的时间锚点（≤15 字短语，如：开篇前夕、三年后、大婚当日）。post_processing 将其作为 world_event_digest 每条条目的 time 字段。"
    },
    "location_anchor": {
      "type": "string",
      "maxLength": 15,
      "description": "本阶段的主要发生地锚点（≤15 字短语，如：某宗门、某城外）。post_processing 将其作为 world_event_digest 每条条目的 location 字段。"
    },
    "snapshot_summary": {
      "type": "string"
    },
    "chapter_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "foundation_corrections": {
      "type": "array",
      "description": "对基础设定（foundation）的修正与补充。随着剧情推进，原始设定可能被补充或推翻。",
      "items": {
        "type": "string"
      }
    },
    "stage_events": {
      "type": "array",
      "description": "本阶段发生的**世界级事件**（仅本阶段，不累积历史），每条为 50–80 字的一句话摘要。既作为快照中的事件清单，也是 world_event_digest.jsonl 程序化累积的直接来源；1:1 展开，连续编号。仅记录世界公共层事件（势力变迁、地形/资源变化、规则揭示、跨角色公共事件），角色个人剧情事件归入对应角色的 stage_events / memory_timeline。不需要逐条标注章节引用。",
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 50,
        "maxLength": 80
      }
    },
    "current_world_state": {
      "type": "array",
      "description": "当前阶段的世界总体状态。",
      "items": {
        "type": "string"
      }
    },
    "relationship_shifts": {
      "type": "array",
      "description": "关注的人物关系的转变。",
      "items": {
        "type": "string"
      }
    },
    "character_status_changes": {
      "type": "array",
      "description": "人物的状态变化（生死、恋爱、等级等随时间变化的状态）。",
      "items": {
        "type": "string"
      }
    },
    "location_changes": {
      "type": "array",
      "description": "地点的变化（新地点出现、旧地点毁灭等）。",
      "items": {
        "type": "string"
      }
    },
    "map_changes": {
      "type": "array",
      "description": "地图的变化（势力范围、领土变动等）。",
      "items": {
        "type": "string"
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "description": "本阶段引用的章节号列表，如 [\"0001\", \"0002\"]。",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{4}$"
      }
    }
  }
}
