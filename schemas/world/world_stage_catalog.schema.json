{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world/world_stage_catalog.schema.json",
  "title": "世界阶段目录",
  "description": "阶段索引，仅用于 bootstrap 阶段选择，运行时不加载。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "default_stage_id": {
      "type": "string",
      "pattern": "^S[0-9]{3}$",
      "description": "默认阶段标识，紧凑英文代号 S###。"
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "stage_title",
          "summary",
          "snapshot_path"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "pattern": "^S[0-9]{3}$",
            "description": "作品级阶段标识，紧凑英文代号 S###；条目排序直接按此字段字典序。"
          },
          "stage_title": {
            "type": "string",
            "description": "阶段的人类可读短标题。"
          },
          "timeline_anchor": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "description": "世界事件概要（本阶段世界发生了什么），供 bootstrap 阶段选择时展示。"
          },
          "chapter_scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          },
          "snapshot_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
