{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world/world_stage_catalog.schema.json",
  "title": "世界阶段目录",
  "description": "阶段索引，仅用于 bootstrap 阶段选择，运行时不加载。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "default_stage_id": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "order",
          "title",
          "summary",
          "snapshot_path"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "timeline_anchor": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "世界事件概要（本阶段世界发生了什么），供 bootstrap 阶段选择时展示。"
          },
          "chapter_scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          },
          "snapshot_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
