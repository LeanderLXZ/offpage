{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world/fixed_relationships.schema.json",
  "title": "世界级固定关系网络",
  "description": "不随阶段变化的结构性纽带（血缘、师承、门派归属等）。Phase 2 产出骨架，后续 stage 维护修正。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "relationships"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1
    },
    "relationships": {
      "type": "array",
      "description": "固定关系条目列表",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relationship_id", "type", "parties", "description"],
        "properties": {
          "relationship_id": {
            "type": "string",
            "description": "唯一标识符，如 FR-001"
          },
          "type": {
            "type": "string",
            "description": "关系类型（如 血缘、师承、门派归属、血亲、结义等）"
          },
          "parties": {
            "type": "array",
            "description": "关系涉及的角色名（至少2个）",
            "items": {
              "type": "string"
            },
            "minItems": 2
          },
          "description": {
            "type": "string",
            "maxLength": 100,
            "description": "关系的具体描述，≤100 字。"
          }
        }
      }
    }
  }
}
