{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world_stage_catalog.schema.json",
  "title": "世界阶段目录",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "default_stage_id": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "order",
          "title",
          "short_summary",
          "snapshot_path"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "timeline_anchor": {
            "type": "string"
          },
          "short_summary": {
            "type": "string",
            "minLength": 1,
            "description": "供用户选择阶段时展示的一句话摘要。"
          },
          "chapter_scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          },
          "current_world_summary": {
            "type": "string"
          },
          "history_summary": {
            "type": "string"
          },
          "snapshot_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
