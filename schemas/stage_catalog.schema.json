{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/stage_catalog.schema.json",
  "title": "Stage Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "character_id",
    "work_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "character_id": {
      "type": "string"
    },
    "work_id": {
      "type": "string"
    },
    "default_stage_id": {
      "type": "string"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "order",
          "title",
          "short_summary",
          "snapshot_path"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "timeline_anchor": {
            "type": "string"
          },
          "short_summary": {
            "type": "string",
            "minLength": 1
          },
          "experience_summary": {
            "type": "string"
          },
          "relationship_summary": {
            "type": "string"
          },
          "personality_summary": {
            "type": "string"
          },
          "knowledge_boundary_summary": {
            "type": "string"
          },
          "chapter_scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          },
          "snapshot_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
