{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/stage_catalog.schema.json",
  "title": "角色阶段目录",
  "description": "角色阶段索引，仅用于 bootstrap 阶段选择，运行时不加载。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "character_id",
    "work_id",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级基础角色标识。对于中文作品，优先直接使用原始中文标识。"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "default_stage_id": {
      "type": "string",
      "minLength": 1,
      "description": "默认阶段标识。对于中文作品，这个值可以直接是中文。"
    },
    "stages": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "order",
          "title",
          "summary",
          "snapshot_path"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1,
            "description": "作品级阶段标识。对于中文作品，优先直接使用原始中文标识，而不是拼音 id。"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "timeline_anchor": {
            "type": "string"
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "description": "供 bootstrap 阶段选择时展示的摘要。"
          },
          "experience_summary": {
            "type": "string"
          },
          "relationship_summary": {
            "type": "string"
          },
          "personality_summary": {
            "type": "string"
          },
          "current_status_summary": {
            "type": "string"
          },
          "current_mood_summary": {
            "type": "string"
          },
          "voice_shift_summary": {
            "type": "string"
          },
          "knowledge_boundary_summary": {
            "type": "string"
          },
          "chapter_scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          },
          "snapshot_path": {
            "type": "string",
            "description": "该阶段对应的快照路径。如果 stage_id 为中文，则由它派生出来的路径段也应使用中文。"
          }
        }
      }
    }
  }
}
