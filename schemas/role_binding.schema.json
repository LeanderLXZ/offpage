{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/role_binding.schema.json",
  "title": "角色绑定",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "user_id",
    "work_id",
    "character_id",
    "stage_id",
    "counterpart_mode",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "当前角色绑定所属的作品命名空间标识。该值必须与 `users/{user_id}/works/{work_id}/` 的路径一致。对于中文作品，这个值可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "当前绑定的目标基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "description": "当前绑定的作品级活动阶段标识。该阶段先作为 work-level timeline checkpoint 选定，再投影到目标角色。对于中文作品，这个值可以直接是中文。"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "counterpart_mode": {
      "type": "string",
      "enum": [
        "user_self",
        "user_persona",
        "canon_character",
        "custom_role"
      ],
      "description": "当前用户侧身份模式。可以是用户本人、已有 persona、作品中的另一个 canon 角色，或自定义身份。"
    },
    "counterpart_persona_id": {
      "type": "string"
    },
    "counterpart_character_id": {
      "type": "string",
      "minLength": 1,
      "description": "当用户侧身份模式为 canon_character 时，该值表示用户侧角色所绑定的基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "counterpart_stage_mode": {
      "type": "string",
      "enum": [
        "inherit_target_stage",
        "explicit_override"
      ],
      "description": "canon 用户侧角色的阶段绑定模式。默认推荐 inherit_target_stage。"
    },
    "counterpart_stage_id": {
      "type": "string",
      "minLength": 1,
      "description": "当 counterpart_stage_mode 为 explicit_override 时，该值表示用户侧角色显式覆盖后的阶段标识。默认运行时不应要求用户单独选择该值。"
    },
    "counterpart_label": {
      "type": "string"
    },
    "counterpart_summary": {
      "type": "string"
    },
    "default_context_lifecycle": {
      "type": "string",
      "enum": [
        "ephemeral",
        "persistent"
      ]
    },
    "default_merge_policy": {
      "type": "string",
      "enum": [
        "manual_only",
        "allow_memory_pins",
        "allow_full_merge"
      ]
    },
    "default_writeback_policy": {
      "type": "string",
      "enum": [
        "continuous",
        "review_only",
        "manual_only"
      ]
    },
    "auto_resume_last_context": {
      "type": "boolean"
    },
    "preferred_context_id": {
      "type": "string"
    },
    "last_context_id": {
      "type": "string"
    },
    "last_session_id": {
      "type": "string"
    },
    "preferred_terminal": {
      "type": "string",
      "enum": [
        "agent",
        "app",
        "mcp",
        "other"
      ]
    },
    "setup_locked": {
      "type": "boolean",
      "description": "是否已经完成首次设定并锁定账号绑定。锁定后，普通 runtime 不应随意修改 work / 角色 / 阶段 / 身份模式。"
    },
    "bootstrap_completed_at": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "counterpart_mode": {
            "const": "user_persona"
          }
        }
      },
      "then": {
        "required": [
          "counterpart_persona_id"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_persona_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "user_persona"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        }
      },
      "then": {
        "required": [
          "counterpart_character_id",
          "counterpart_stage_mode"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_character_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "counterpart_stage_mode"
        ]
      },
      "then": {
        "required": [
          "counterpart_mode"
        ],
        "properties": {
          "counterpart_mode": {
            "const": "canon_character"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "counterpart_stage_mode": {
            "const": "explicit_override"
          }
        }
      },
      "then": {
        "required": [
          "counterpart_stage_id"
        ]
      }
    },
    {
      "if": {
        "required": [
          "counterpart_stage_id"
        ]
      },
      "then": {
        "required": [
          "counterpart_stage_mode"
        ],
        "properties": {
          "counterpart_stage_mode": {
            "const": "explicit_override"
          }
        }
      }
    }
  ]
}
