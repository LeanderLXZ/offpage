{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/world_stage_snapshot.schema.json",
  "title": "世界阶段快照",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "stage_id",
    "title",
    "snapshot_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "timeline_anchor": {
      "type": "string"
    },
    "snapshot_summary": {
      "type": "string"
    },
    "chapter_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "foundation_corrections": {
      "type": "array",
      "description": "对基础设定（foundation）的修正与补充。随着剧情推进，原始设定可能被补充或推翻。",
      "items": {
        "type": "string"
      }
    },
    "historical_events": {
      "type": "array",
      "description": "截至当前阶段的累积历史事件。",
      "items": {
        "type": "string"
      }
    },
    "current_world_state": {
      "type": "array",
      "description": "当前阶段的世界总体状态。",
      "items": {
        "type": "string"
      }
    },
    "relationship_shifts": {
      "type": "array",
      "description": "关注的人物关系的转变。",
      "items": {
        "type": "string"
      }
    },
    "character_status_changes": {
      "type": "array",
      "description": "人物的状态变化（生死、恋爱、等级等随时间变化的状态）。",
      "items": {
        "type": "string"
      }
    },
    "location_changes": {
      "type": "array",
      "description": "地点的变化（新地点出现、旧地点毁灭等）。",
      "items": {
        "type": "string"
      }
    },
    "map_changes": {
      "type": "array",
      "description": "地图的变化（势力范围、领土变动等）。",
      "items": {
        "type": "string"
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
