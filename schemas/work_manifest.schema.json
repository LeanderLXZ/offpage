{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/work_manifest.schema.json",
  "title": "Work Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "title",
    "source_types",
    "ingestion_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string"
    },
    "source_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "web",
          "epub",
          "txt",
          "manual_excerpt",
          "summary"
        ]
      }
    },
    "ingestion_status": {
      "type": "string",
      "enum": [
        "planned",
        "raw_imported",
        "normalized",
        "chunked",
        "indexed",
        "active"
      ]
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_root": {
          "type": "string"
        },
        "normalized_root": {
          "type": "string"
        },
        "chapter_root": {
          "type": "string"
        },
        "scene_root": {
          "type": "string"
        },
        "chunk_root": {
          "type": "string"
        },
        "rag_root": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
