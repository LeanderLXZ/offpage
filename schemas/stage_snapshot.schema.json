{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona-engine/stage_snapshot.schema.json",
  "title": "阶段快照",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "character_id",
    "stage_id",
    "title",
    "snapshot_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品包命名空间键。对于中文作品，这个值本身也可以直接是中文。"
    },
    "character_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级基础角色标识。对于中文作品，这个值可以直接是中文。"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "description": "作品级阶段标识。对于中文作品，这个值可以直接是中文。"
    },
    "title": {
      "type": "string"
    },
    "timeline_anchor": {
      "type": "string"
    },
    "snapshot_summary": {
      "type": "string"
    },
    "chapter_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "experienced_events": {
      "type": "array",
      "description": "截至当前阶段，角色已经历过的关键事件。",
      "items": {
        "type": "string"
      }
    },
    "current_status": {
      "type": "array",
      "description": "当前阶段角色的状态信息，例如生死、关系、等级、位置等。",
      "items": {
        "type": "string"
      }
    },
    "current_personality": {
      "type": "array",
      "description": "当前阶段下已经稳定显现的人格与处事倾向。",
      "items": {
        "type": "string"
      }
    },
    "current_mood": {
      "type": "array",
      "description": "当前阶段下更接近现在进行时的情绪背景。",
      "items": {
        "type": "string"
      }
    },
    "knowledge_scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "knows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "does_not_know": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "emotional_baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dominant_traits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_desires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_fears": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "active_wounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "voice_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tone_summary": {
          "type": "string"
        },
        "current_voice_state": {
          "type": "string"
        },
        "speech_habits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "taboo_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "behavior_overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "under_stress": {
          "type": "string"
        },
        "with_strangers": {
          "type": "string"
        },
        "with_intimates": {
          "type": "string"
        },
        "conflict_style": {
          "type": "string"
        }
      }
    },
    "relationship_state_summary": {
      "type": "string"
    },
    "relationship_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_label",
          "summary"
        ],
        "properties": {
          "target_character_id": {
            "type": "string",
            "minLength": 1,
            "description": "被引用的基础角色标识。对于中文作品，这个值可以直接是中文。"
          },
          "target_label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "trust": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "guardedness": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "memory_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
