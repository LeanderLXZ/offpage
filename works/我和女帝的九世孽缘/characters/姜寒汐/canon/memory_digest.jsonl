{"memory_id": "M-S001-01", "summary": "破境重修降生时虚空错乱，被迫抛弃北境选址，落入陌生的南林荒野。", "importance": "critical", "time": "破境重修降生时", "location": "虚空传送途中—南林荒野"}
{"memory_id": "M-S001-02", "summary": "降生刚出传送虚空即被树上贼子偷窥裸身，对方蹦走无踪，成她几万年来的新黑历史。", "importance": "significant", "time": "降生当刻", "location": "南林荒野·传送门落点"}
{"memory_id": "M-S001-03", "summary": "返身归来的贼子以诡异瞬步避过她的寒剑，自背后一记手刀将她劈晕。", "importance": "significant", "time": "降生当日稍后", "location": "南林荒野"}
{"memory_id": "M-S001-04", "summary": "醒来发现被奇丑倭瓜男捆缚欲辱，她以口中寒针反击未中，贼子击头后借力逃脱。", "importance": "critical", "time": "苏醒之夜", "location": "柳村·某陌生屋内"}
{"memory_id": "M-S001-05", "summary": "剑气破墙冲出追贼子，众村民中无那倭瓜男，却对一青年生出莫名熟悉感。", "importance": "significant", "time": "苏醒当夜稍后", "location": "柳村·村道"}
{"memory_id": "M-S001-06", "summary": "村道边盘坐修炼帝冰诀，思及残篇之憾与破境重修后仅剩三件法器的窘境。", "importance": "significant", "time": "苏醒当夜", "location": "柳村·村道一侧"}
{"memory_id": "M-S001-07", "summary": "小孩代那青年送鸟蛋，她偷尝后被对方看见，尴尬心虚又庆幸身份未露。", "importance": "minor", "time": "篝火夜", "location": "柳村·大柳树下篝火旁"}
{"memory_id": "M-S001-08", "summary": "他强塞妖兽肉并握她手，她应激后不熟练道谢，首次吃肉觉味胜鸟蛋。", "importance": "significant", "time": "篝火夜", "location": "柳村·大柳树下篝火旁"}
{"memory_id": "M-S001-09", "summary": "他以“没人要的孩子”之语触其核心创伤，她起身随入屋中，并主动问他眼熟。", "importance": "defining", "time": "入夜", "location": "柳村·大柳树下与村屋"}
{"memory_id": "M-S001-10", "summary": "他坚持睡地板；次日她见他怪姿俯卧撑，斥其单相思，对方欲道心起誓自证。", "importance": "minor", "time": "翌日早晨", "location": "柳村·村屋内"}
{"memory_id": "M-S001-11", "summary": "他为救村民力竭晕倒，她坐守至夜并主动按胸传灵疗伤，问他“为什么救人”。", "importance": "critical", "time": "入夜", "location": "柳村·大柳树下与村屋"}
