{
  "schema_version": "1.0.0",
  "work_id": "我和女帝的九世孽缘",
  "default_policy": {
    "startup_mode": "minimal_required",
    "history_mode": "on_demand",
    "raw_chapter_mode": "verify_only"
  },
  "startup_required": {
    "world": [
      "world/manifest.json",
      "world/stage_catalog.json",
      "world/stage_snapshots/{stage_id}.json",
      "world/social/stage_relationships/{stage_id}.json",
      "world/foundation/setting.json",
      "world/foundation/power_system.json"
    ],
    "character": [
      "characters/{character_id}/manifest.json",
      "characters/{character_id}/canon/stage_catalog.json",
      "characters/{character_id}/canon/stage_snapshots/{stage_id}.json"
    ],
    "user": [
      "users/{user_id}/profile.json",
      "users/{user_id}/personas/{persona_id}.json",
      "users/{user_id}/conversation_library/manifest.json",
      "users/{user_id}/conversation_library/scopes/{work_id}/{character_id}/archive_refs.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/role_binding.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/long_term_profile.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/relationship_core/manifest.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/relationship_core/pinned_memories.jsonl",
      "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/manifest.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/relationship_state.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/shared_memory.jsonl",
      "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/session_index.json",
      "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/sessions/{recent_session_id}/turn_summaries.jsonl"
    ]
  },
  "on_demand_buckets": [
    {
      "bucket": "world_event_lookup",
      "trigger": "用户询问某个重大事件、战斗、事故或阶段转折",
      "load": [
        "world/events/{event_id}.json",
        "world/history/timeline.jsonl"
      ]
    },
    {
      "bucket": "location_or_faction_lookup",
      "trigger": "用户询问地点、势力、阵营、宗门、皇朝、地图",
      "load": [
        "world/locations/{location_id}/identity.json",
        "world/factions/{faction_id}.json"
      ]
    },
    {
      "bucket": "historical_relationship_lookup",
      "trigger": "用户询问过去阶段的人物关系变化",
      "load": [
        "world/social/stage_relationships/{historical_stage_id}.json",
        "world/stage_snapshots/{historical_stage_id}.json"
      ]
    },
    {
      "bucket": "character_memory_lookup",
      "trigger": "用户询问某角色亲历、误解、记忆细节、过去经历",
      "load": [
        "characters/{character_id}/canon/memory_timeline.jsonl",
        "characters/{character_id}/canon/stage_snapshots/{stage_id}.json"
      ]
    },
    {
      "bucket": "user_context_history_lookup",
      "trigger": "用户询问之前聊过什么、某段旧对话细节、之前是谁说了什么、当前 context 的历史连续性",
      "load": [
        "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/session_index.json",
        "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/sessions/{session_id}/turn_summaries.jsonl",
        "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/sessions/{session_id}/transcript.jsonl",
        "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/sessions/{session_id}/turn_journal.jsonl",
        "users/{user_id}/works/{work_id}/characters/{character_id}/contexts/{context_id}/sessions/{session_id}/memory_updates.jsonl"
      ]
    },
    {
      "bucket": "account_archive_lookup",
      "trigger": "用户询问已并入账户库的旧对话、旧 context、很早之前聊过的内容或需要跨 context 查找历史聊天",
      "load": [
        "users/{user_id}/conversation_library/archive_index.jsonl",
        "users/{user_id}/conversation_library/scopes/{work_id}/{character_id}/archive_refs.json",
        "users/{user_id}/conversation_library/archives/{archive_id}/manifest.json",
        "users/{user_id}/conversation_library/archives/{archive_id}/context_summary.json",
        "users/{user_id}/conversation_library/archives/{archive_id}/key_moments.jsonl",
        "users/{user_id}/conversation_library/archives/{archive_id}/session_index.json",
        "users/{user_id}/conversation_library/archives/{archive_id}/sessions/{session_id}/turn_summaries.jsonl",
        "users/{user_id}/conversation_library/archives/{archive_id}/sessions/{session_id}/transcript.jsonl"
      ]
    },
    {
      "bucket": "raw_chapter_verification",
      "trigger": "摘要不足、证据冲突、用户要求高细节或原文核验",
      "load": [
        "sources/works/{work_id}/chapters/{chapter_id}.txt"
      ]
    }
  ],
  "retrieval_pipeline": [
    "先解析用户问题属于世界、关系、历史、角色记忆、当前 context 对话历史、账户归档对话还是原文核验。",
    "先用结构化 id 与当前 stage 过滤范围。",
    "先取摘要层文件，不够再下钻到详细文件。",
    "只有在证据不足或高模式下才加载原文章节。"
  ],
  "chapter_ref_template": "sources/works/{work_id}/chapters/{chapter_id}.txt",
  "notes": "当前作品默认先加载当前 stage 的关系文件、当前 context 摘要层状态与当前作用域下的 archive refs，不默认加载历史关系或完整用户对话 transcript。历史关系、旧阶段状态、完整 transcript、账户归档正文与原文章节都属于按需检索层。"
}
